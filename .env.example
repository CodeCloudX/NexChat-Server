# === PROJECT CONFIG ===
PROJECT_NAME=NexChat
ENV=development
DEBUG=True
SECRET_KEY=yahan_aapka_lamba_random_secret_daalein

# === DATABASE (Supabase / Postgres) ===
# Example: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:your_password@db.your_project.supabase.co:5432/postgres

# === REDIS (Upstash / Local) ===
# Example: redis://default:pass@host:6379
REDIS_URL=redis://default:your_password@your_redis_host:6379

# === EMAIL (Brevo API) ===
BREVO_API_KEY=xkeysib-your_api_key_yahan_daalein
EMAILS_FROM_EMAIL=your_verified_sender@gmail.com
EMAILS_FROM_NAME=NexChat

# === FIREBASE / GOOGLE AUTH ===
# Path to your service account JSON file
FIREBASE_CREDENTIALS=firebase/service-account.json

# === STORAGE (Supabase Storage) ===
STORAGE_TYPE=supabase
STORAGE_URL=https://your_project.supabase.co
STORAGE_KEY=your_supabase_anon_or_service_role_key
STORAGE_BUCKET=nexchat-media

# === CORS SETTINGS ===
# Commma separated list of allowed origins
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000
